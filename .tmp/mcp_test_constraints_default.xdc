## BackPlane reference
######################################################################
set_property -dict {PACKAGE_PIN R25 IOSTANDARD LVCMOS33} [get_ports clk_13mhz5_i]
set_property -dict {PACKAGE_PIN N26 IOSTANDARD LVCMOS33} [get_ports clk_13mhz5_en_o]
######################################################################
## Audio Interface
######################################################################
set_property -dict {PACKAGE_PIN W21 IOSTANDARD LVCMOS33} [get_ports aes_i]
set_property -dict {PACKAGE_PIN W24 IOSTANDARD LVCMOS33} [get_ports aes_o]
set_property -dict {PACKAGE_PIN W25 IOSTANDARD LVCMOS33} [get_ports clk_aud_o]
set_property -dict {PACKAGE_PIN W26 IOSTANDARD LVCMOS33} [get_ports wclk_o]
set_property PACKAGE_PIN G22 [get_ports f_si_a_clk3_p]
set_property PACKAGE_PIN F23 [get_ports f_si_a_clk3_n]
######################################################################
## DCI CASCADE MIG
######################################################################
set_property DCI_CASCADE {32 34} [get_iobanks 33]
######################################################################
## Keeping hierarchy DRU
######################################################################
set_property KEEP_HIERARCHY true [get_cells -hier *NIDRU*]

######################################################################
## Asynchronous data
######################################################################
set_property ASYNC_REG true [get_cells -hier -filter name=~*d1_cdc_to*]
set_property ASYNC_REG true [get_cells -hier -filter name=~*_d2*]
set_property ASYNC_REG true [get_cells -hier -filter name=~*_d3*]
#
set_property SHREG_EXTRACT NO [get_cells -hier -filter name=~*d1_cdc_to*]
set_property SHREG_EXTRACT NO [get_cells -hier -filter name=~*_d2*]
set_property SHREG_EXTRACT NO [get_cells -hier -filter name=~*_d3*]

#
set_property ASYNC_REG true [get_cells -hier -filter {name=~*tof_gen_a_ins/tof_reg[*]}]
set_property SHREG_EXTRACT NO [get_cells -hier -filter {name=~*tof_gen_a_ins/tof_reg[*]}]
#
set_property ASYNC_REG true [get_cells -hier -filter name=~*_ss*]
set_property SHREG_EXTRACT NO [get_cells -hier -filter name=~*_ss*]

