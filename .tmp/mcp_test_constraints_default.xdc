######################################################################

set _xlnx_shared_i0 [get_cells * -hier -filter {name =~*TX/TXEDH*      && IS_PRIMITIVE && IS_SEQUENTIAL}]
set_multicycle_path -setup -from $_xlnx_shared_i0 5
set_multicycle_path -hold -from $_xlnx_shared_i0 4


