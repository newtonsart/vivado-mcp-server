####################################################################################
# Constraints from file : 'usw2000_timing.xdc'
####################################################################################

## TIMING CONSTRAINTS

## Exceptions priority
# 1- Clock Groups (set_clock_groups)
# 2- False Path (set_false_path)
# 3- Maximum and Minimum Delay Path (set_max_delay and set_min_delay)
# 4- Multicycle Paths (set_multicycle_path)

######################################################################
## CREATE_CLOCK
######################################################################

current_instance -quiet
create_clock -period 37.037 -name clk_27mhz -waveform {0.000 18.519} [get_ports clk_27mhz_i]
create_clock -period 74.074 -name clk_13mhz5 -waveform {0.000 37.037} [get_ports clk_13mhz5_i]
create_clock -period 37.037 -name clk_27mhz -waveform {0.000 18.519} [get_ports clk_27mhz_i]
create_clock -period 3.367 -name tx0_outclk -waveform {0.000 1.684} [get_pins -hier -filter {name=~*uhdsdi_gen[0].*GTXE2*/TXOUTCLK}]
create_clock -period 3.367 -name rx0_outclk -waveform {0.000 1.684} [get_pins -hier -filter {name=~*uhdsdi_gen[0].*GTXE2*/RXOUTCLK}]
create_clock -period 3.367 -name rx1_outclk -waveform {0.000 1.684} [get_pins -hier -filter {name=~*uhdsdi_gen[1].*GTXE2*/RXOUTCLK}]
create_clock -period 3.367 -name rx2_outclk -waveform {0.000 1.684} [get_pins -hier -filter {name=~*uhdsdi_gen[2].*GTXE2*/RXOUTCLK}]
create_clock -period 3.367 -name rx3_outclk -waveform {0.000 1.684} [get_pins -hier -filter {name=~*uhdsdi_gen[3].*GTXE2*/RXOUTCLK}]
#create_clock -period 20.000 -name rmii_clk -waveform {0.000 10.000} [get_ports rmii_clk_i]
#create_clock -period 20.000 -name rmii_mdc -waveform {0.000 10.000} [get_ports rmii_mdc_i]
create_clock -period 8.000 -name rmii_clk -waveform {0.000 4.000} [get_ports rgmii_txc_i]
create_clock -period 20.000 -name rmii_mdc -waveform {0.000 10.000} [get_ports phy_emulator_mdc]
create_clock -period 6.734 -name mgtclk0 -waveform {0.000 3.367} [get_ports {gtx_refclk_p_i[0]}]
create_clock -period 6.734 -name mgtclk1 -waveform {0.000 3.367} [get_ports {gtx_refclk_p_i[1]}]
create_clock -period 20.300 -name aud_clk -waveform {0.000 10.150} [get_ports f_si_a_clk3_p]

######################################################################
## CREATE_GENERATED_CLOCK
######################################################################

create_generated_clock -name clk_50mhz clk_gen_inst/pll_20mhz_inst/CLKOUT0
create_generated_clock -name clk_125mhz clk_gen_inst/pll_20mhz_inst/CLKOUT1
create_generated_clock -name clk_135mhz clk_gen_inst/pll_27mhz_inst/CLKOUT1



create_generated_clock -name nidru_clk0 -source [get_pins -hier -filter {name=~*uhdsdi_gen[0].*GTXE2*/RXOUTCLK}] -divide_by 2 [get_pins -hier -filter {name=~*uhdsdi_gen[0].**NIDRU_INST/CLK}]
create_generated_clock -name nidru_clk1 -source [get_pins -hier -filter {name=~*uhdsdi_gen[1].*GTXE2*/RXOUTCLK}] -divide_by 2 [get_pins -hier -filter {name=~*uhdsdi_gen[1].**NIDRU_INST/CLK}]
create_generated_clock -name nidru_clk2 -source [get_pins -hier -filter {name=~*uhdsdi_gen[2].*GTXE2*/RXOUTCLK}] -divide_by 2 [get_pins -hier -filter {name=~*uhdsdi_gen[2].**NIDRU_INST/CLK}]
create_generated_clock -name nidru_clk3 -source [get_pins -hier -filter {name=~*uhdsdi_gen[3].*GTXE2*/RXOUTCLK}] -divide_by 2 [get_pins -hier -filter {name=~*uhdsdi_gen[3].**NIDRU_INST/CLK}]
create_generated_clock -name drpclk_i -source [get_ports {gtx_refclk_p_i[1]}] -divide_by 2 [get_pins -hier -filter name=~*MGTCLKIN1*/ODIV2]


######################################################################
## SET_INPUT_DELAY
######################################################################
set_input_delay -clock rmii_clk -max 4.100 [get_ports {{rgmii_txd_i[*]} rgmii_tx_ctl_i}]
set_input_delay -clock rmii_clk -min 4.000 [get_ports {{rgmii_txd_i[*]} rgmii_tx_ctl_i}]

######################################################################
## SET_OUTPUT_DELAY
######################################################################

######################################################################
## SET_CLOCK_GROUPS
######################################################################
## EXCLUSIVE
set_clock_groups -physically_exclusive -group [get_clocks -include_generated_clocks rx0_outclk] -group [get_clocks -include_generated_clocks rx1_outclk] -group [get_clocks -include_generated_clocks rx2_outclk] -group [get_clocks -include_generated_clocks rx3_outclk]


## ASYNCHROUNOUS
set_clock_groups -asynchronous -group [get_clocks rx1_outclk] -group [get_clocks drpclk_i]
set_clock_groups -asynchronous -group [get_clocks rx2_outclk] -group [get_clocks drpclk_i]
set_clock_groups -asynchronous -group [get_clocks rx3_outclk] -group [get_clocks drpclk_i]
set_clock_groups -asynchronous -group [get_clocks drpclk_i] -group [get_clocks rx0_outclk*]
set_clock_groups -asynchronous -group [get_clocks drpclk_i] -group [get_clocks rx1_outclk]
set_clock_groups -asynchronous -group [get_clocks drpclk_i] -group [get_clocks rx2_outclk]
set_clock_groups -asynchronous -group [get_clocks drpclk_i] -group [get_clocks rx3_outclk]


######################################################################
## SET_FALSE_PATH
######################################################################

set_false_path -from [get_clocks aud_clk] -to [get_clocks clk_50mhz]
set_false_path -from [get_clocks aud_clk] -to [get_clocks clkout2]

set_false_path -from [get_clocks clk_125mhz] -to [get_clocks clkout2]
set_false_path -from [get_clocks clk_125mhz] -to [get_clocks clk_50mhz]
set_false_path -from [get_clocks clk_125mhz] -to [get_clocks rmii_clk]
set_false_path -from [get_clocks clk_125mhz] -to [get_clocks rmii_mdc]
set_false_path -from [get_clocks clk_125mhz] -to [get_clocks clk_125_90mhz]

set_false_path -from [get_clocks clk_13mhz5] -to [get_clocks clk_135mhz]
set_false_path -from [get_clocks clk_13mhz5] -to [get_clocks clk_50mhz]

